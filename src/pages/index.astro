<!-- ========== Sticky bottom CTA ========== -->
<div class="sticky-bar" id="sticky-bar" aria-hidden="true">
  <div class="label">Founding cohort · <span class="price-strong">$590</span>/mo<small>Month-to-month · Cancel anytime</small></div>
  <a href="#apply" class="btn btn--primary">Apply Now <span class="arrow" aria-hidden="true">→</span></a>
</div>

<script is:inline>
(function () {
  // ---- Smooth scroll for in-page anchors ----
  document.querySelectorAll('a[href^="#"]').forEach(function (a) {
    a.addEventListener('click', function (e) {
      var id = this.getAttribute('href');
      if (id.length < 2) return;
      var tgt = document.querySelector(id);
      if (!tgt) return;
      e.preventDefault();
      tgt.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // ---- Tabs ----
  var tabBtns = document.querySelectorAll('.tab-btn');
  var tabPanels = document.querySelectorAll('.tab-panel');
  tabBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      tabBtns.forEach(function (b) { b.setAttribute('aria-selected', b === btn ? 'true' : 'false'); });
      var target = btn.getAttribute('aria-controls');
      tabPanels.forEach(function (p) {
        if (p.id === target) p.setAttribute('data-active', '');
        else p.removeAttribute('data-active');
      });
    });
    btn.addEventListener('keydown', function (e) {
      var idx = Array.prototype.indexOf.call(tabBtns, btn);
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault();
        tabBtns[(idx + 1) % tabBtns.length].click();
        tabBtns[(idx + 1) % tabBtns.length].focus();
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault();
        var prev = (idx - 1 + tabBtns.length) % tabBtns.length;
        tabBtns[prev].click();
        tabBtns[prev].focus();
      }
    });
  });

  // ---- Sticky bottom CTA ----
  var stickyBar = document.getElementById('sticky-bar');
  var hero = document.querySelector('.hero');
  var applySection = document.getElementById('apply');
  function updateStickyBar() {
    if (!stickyBar || !hero || !applySection) return;
    var heroBottom = hero.getBoundingClientRect().bottom;
    var applyTop = applySection.getBoundingClientRect().top;
    var viewportH = window.innerHeight;
    var shouldShow = heroBottom < 0 && applyTop > viewportH * 0.5;
    if (shouldShow) {
      stickyBar.classList.add('visible');
      stickyBar.setAttribute('aria-hidden', 'false');
      document.body.classList.add('has-sticky');
    } else {
      stickyBar.classList.remove('visible');
      stickyBar.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('has-sticky');
    }
  }
  window.addEventListener('scroll', updateStickyBar, { passive: true });
  window.addEventListener('resize', updateStickyBar);
  updateStickyBar();

  // ---- Reveal-on-scroll ----
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (en) {
        if (en.isIntersecting) {
          en.target.classList.add('in');
          io.unobserve(en.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('[data-reveal]').forEach(function (el) { io.observe(el); });
  } else {
    document.querySelectorAll('[data-reveal]').forEach(function (el) { el.classList.add('in'); });
  }

  // ---- Multi-step form ----
  var form = document.querySelector('.apply-form');
  if (form) {
    var steps = form.querySelectorAll('.form-step');
    var nextBtn = form.querySelector('[data-next]');
    var backBtn = form.querySelector('[data-back]');
    var submitBtn = form.querySelector('[data-submit]');
    var stepNum = document.getElementById('step-num');
    var segments = form.querySelectorAll('.progress-segment');
    var current = 0;

    function render() {
      steps.forEach(function (s, i) { s.classList.toggle('active', i === current); });
      backBtn.hidden = (current === 0);
      var isLast = (current === steps.length - 1);
      nextBtn.disabled = isLast;
      nextBtn.setAttribute('aria-disabled', isLast ? 'true' : 'false');
      nextBtn.classList.toggle('is-disabled', isLast);
      submitBtn.disabled = !isLast;
      submitBtn.setAttribute('aria-disabled', isLast ? 'false' : 'true');
      submitBtn.classList.toggle('is-disabled', !isLast);
      if (stepNum) stepNum.textContent = String(current + 1).padStart(2, '0');
      segments.forEach(function (seg, i) {
        seg.classList.toggle('active', i === current);
        seg.classList.toggle('complete', i < current);
      });
    }

    function setFormMessage(message, isError) {
      var fine = form.querySelector('.form-fine');
      if (!fine) return;
      fine.textContent = message;
      fine.style.color = isError ? 'var(--c-red)' : 'var(--c-sage-deep)';
    }

    function validateStep() {
      var step = steps[current];
      var required = step.querySelectorAll('[required]');
      for (var i = 0; i < required.length; i++) {
        var field = required[i];
        var isRadio = field.type === 'radio';
        var isEmpty = isRadio
          ? !step.querySelector('input[name="' + field.name + '"]:checked')
          : !field.value.trim();
        var isInvalidEmail = field.type === 'email' && !/^[^@\s]+@[^@\s]+\.[^@\s]{2,}$/.test(field.value.trim());
        var isInvalidPhone = field.type === 'tel' && !/^04\d{2}\s?\d{3}\s?\d{3}$/.test(field.value.trim());

        if (isEmpty || isInvalidEmail || isInvalidPhone) {
          var focusTarget = isRadio ? step.querySelector('input[name="' + field.name + '"]') : field;
          focusTarget.focus();
          field.style.borderColor = 'var(--c-red)';
          var message = 'Please complete all required fields before continuing.';
          if (isInvalidEmail) message = 'Please enter a valid email address, like name@example.com.';
          if (isInvalidPhone) message = 'Please enter an Australian mobile number, like 0400 032 231.';
          setFormMessage(message, true);
          setTimeout(function (el) { return function () { el.style.borderColor = ''; }; }(field), 1800);
          return false;
        }
      }
      return true;
    }

    nextBtn.addEventListener('click', function () {
      if (!validateStep()) return;
      if (current < steps.length - 1) { current++; render(); }
    });
    backBtn.addEventListener('click', function () {
      if (current > 0) { current--; render(); }
    });

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (!validateStep()) return;

      var endpoint = form.getAttribute('data-leads-endpoint');
      if (!endpoint) {
        setFormMessage('The application form is ready, but the Google Sheets endpoint has not been connected yet.', true);
        return;
      }

      var checkedBusinessType = form.querySelector('input[name="business_type"]:checked');
      var payload = {
        submitted_at: new Date().toISOString(),
        page_url: window.location.href,
        name: form.querySelector('[name="name"]').value.trim(),
        email: form.querySelector('[name="email"]').value.trim(),
        phone: form.querySelector('[name="phone"]').value.trim(),
        business_type: checkedBusinessType ? checkedBusinessType.value : '',
        bottleneck: form.querySelector('[name="bottleneck"]').value.trim()
      };

      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';
      setFormMessage('Submitting your application...', false);

      fetch(endpoint, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'text/plain;charset=utf-8' },
        body: JSON.stringify(payload)
      })
        .then(function () {
          form.reset();
          current = 0;
          render();
          setFormMessage('Thanks — your application has been sent. Simon will be in touch with next steps.', false);
        })
        .catch(function () {
          setFormMessage('Something went wrong while submitting. Please try again, or email Simon directly.', true);
        })
        .finally(function () {
          submitBtn.innerHTML = 'Submit application <span class="arrow" aria-hidden="true">→</span>';
          render();
        });
    });

    render();
  }
})();
</script>

</body>
