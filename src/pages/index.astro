<!-- Fonts: Marmot brand trio (Montserrat, Bitter, Open Sans) + a refined editorial display (Fraunces) for high-impact display moments -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bitter:ital,wght@0,400;0,500;0,600;1,400&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=Montserrat:wght@500;600;700;800&family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

<style is:global>
/* ============================================================
   Marmot Coaching — V3 Prototype
   Design direction: editorial / refined consultancy.
   Brand-faithful (sage + orange + Bitter + Montserrat) elevated
   with a Fraunces display face for high-impact display moments,
   a deliberate cream/ink/sage palette, asymmetric grid in the
   hero, an editorial portrait module, segmented-control
   curriculum and a bespoke multi-step apply form.
   ============================================================ */

:root {
  /* Brand-faithful core */
  --c-sage:        #82a4a6;
  --c-sage-bright: #87b6ba;
  --c-sage-deep:   #5d8385;
  --c-sage-tint:   #e6efef;
  --c-sage-mist:   #f3f7f7;
  --c-navy:        #205f88;
  --c-navy-h4:     #2c4e73;
  --c-orange:      #ff9000;
  --c-orange-soft: #ffac30;

  /* V3 palette extensions — editorial cream/ink */
  --c-cream:       #f4ede1; /* warm paper */
  --c-cream-deep:  #ece2cf;
  --c-ink:         #1a1d1e; /* near-black for editorial moments */
  --c-ink-soft:    #2b3033;
  --c-bone:        #faf7f1;

  --c-text:        #555555;
  --c-text-strong: #2b3033;
  --c-bg:          #ffffff;
  --c-bg-alt:      #f7f7f7;
  --c-border:      #e2e2e2;
  --c-border-soft: #ece8e0;
  --c-footer:      #16191b;
  --c-muted:       #6b7280;
  --c-red:         #b5443a;

  /* Type system */
  --f-display: 'Fraunces', 'Bitter', Georgia, serif;        /* editorial display */
  --f-head:    'Montserrat', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  --f-sub:     'Bitter', Georgia, 'Times New Roman', serif;
  --f-body:    'Open Sans', Helvetica, Arial, sans-serif;
  --f-mono:    'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;

  --container:        1200px;
  --container-narrow: 880px;
  --container-wide:   1320px;
  --pad-y:    96px;
  --pad-y-sm: 64px;
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 14px;

  --ease: cubic-bezier(.2,.7,.2,1);
}

/* ---------- Reset / base ---------- */
* { box-sizing: border-box; }
html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; scroll-padding-top: 80px; }

body {
  margin: 0;
  font-family: var(--f-body);
  font-weight: 500;
  font-size: 16px;
  line-height: 1.7;
  color: var(--c-text);
  background: var(--c-bone);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
}

img { max-width: 100%; height: auto; display: block; }
a { color: var(--c-ink-soft); text-decoration: underline; text-decoration-color: rgba(255,144,0,0.6); text-underline-offset: 3px; transition: color 200ms var(--ease), text-decoration-color 200ms var(--ease); }
a:hover { color: var(--c-orange); text-decoration-color: var(--c-orange); }

::selection { background: var(--c-orange); color: #fff; }

/* ---------- Type system ---------- */
h1, h2, h3, h4, h5 { margin: 0 0 12px; line-height: 1.18; color: var(--c-ink); }
h1, h2 { font-family: var(--f-display); font-weight: 400; letter-spacing: -0.02em; }
h3 { font-family: var(--f-head); font-weight: 700; letter-spacing: -0.005em; }
h4 { font-family: var(--f-sub); font-weight: 500; color: var(--c-navy-h4); line-height: 1.4; }
h5 { font-family: var(--f-head); font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; font-size: 12px; color: var(--c-muted); }

h1 { font-size: clamp(40px, 6.4vw, 88px); line-height: 1.02; }
h2 { font-size: clamp(30px, 3.8vw, 52px); line-height: 1.1; }
h3 { font-size: 22px; }
h4 { font-size: 19px; }

p { margin: 0 0 16px; }
ul { margin: 0 0 16px; padding-left: 22px; }
li { margin-bottom: 6px; }

.container { width: 100%; max-width: var(--container); margin: 0 auto; padding: 0 28px; }
.container--narrow { max-width: var(--container-narrow); }
.container--wide { max-width: var(--container-wide); }

section { padding: var(--pad-y) 0; position: relative; }

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--c-sage-deep);
  margin-bottom: 20px;
}
.eyebrow::before {
  content: "";
  width: 28px;
  height: 1.5px;
  background: var(--c-sage);
  display: inline-block;
}
.eyebrow--orange { color: var(--c-orange); }
.eyebrow--orange::before { background: var(--c-orange); }
.eyebrow--light { color: rgba(255,255,255,0.85); }
.eyebrow--light::before { background: rgba(255,255,255,0.6); }

.section-head { margin-bottom: 56px; max-width: 780px; }
.section-head.center { text-align: center; margin-left: auto; margin-right: auto; }
.section-head .lede {
  font-family: var(--f-sub);
  font-size: 19px;
  line-height: 1.55;
  color: var(--c-text);
  margin: 18px 0 0;
}

/* italic accent — editorial tic */
.italic-accent { font-family: var(--f-display); font-style: italic; font-weight: 400; color: var(--c-sage-deep); }

/* ---------- Buttons ---------- */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 16px 26px;
  border-radius: var(--radius-sm);
  border: 1.5px solid transparent;
  cursor: pointer;
  transition: transform 220ms var(--ease), box-shadow 220ms var(--ease), background 220ms var(--ease), color 220ms var(--ease), border-color 220ms var(--ease);
  text-decoration: none;
  line-height: 1;
  white-space: nowrap;
}
.btn .arrow { transition: transform 260ms var(--ease); }
.btn:hover .arrow { transform: translateX(4px); }
.btn--primary { background: var(--c-orange); color: #fff; box-shadow: 0 1px 0 rgba(0,0,0,0.04), 0 6px 18px rgba(255,144,0,0.18); }
.btn--primary:hover { background: #f08600; color: #fff; transform: translateY(-1px); box-shadow: 0 10px 28px rgba(255,144,0,0.32); text-decoration: none; }
.btn[disabled],
.btn.is-disabled {
  background: #d7d0c4;
  color: rgba(43,48,51,0.46);
  border-color: #d7d0c4;
  box-shadow: none;
  cursor: not-allowed;
  pointer-events: none;
}
.btn[disabled]:hover,
.btn.is-disabled:hover {
  background: #d7d0c4;
  color: rgba(43,48,51,0.46);
  transform: none;
  box-shadow: none;
}
.btn--ghost { background: transparent; color: var(--c-ink); border-color: var(--c-ink); }
.btn--ghost:hover { background: var(--c-ink); color: var(--c-bone); text-decoration: none; }
.btn--ghost-light { background: transparent; color: #fff; border-color: rgba(255,255,255,0.55); }
.btn--ghost-light:hover { background: #fff; color: var(--c-ink); text-decoration: none; }
.btn--lg { padding: 19px 32px; font-size: 13px; }

/* ---------- Header ---------- */
.site-header {
  background: rgba(250,247,241,0.85);
  backdrop-filter: blur(10px) saturate(120%);
  -webkit-backdrop-filter: blur(10px) saturate(120%);
  border-bottom: 1px solid var(--c-border-soft);
  padding: 14px 0;
  position: sticky;
  top: 0;
  z-index: 50;
}
.site-header .container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}
.brand {
  display: inline-flex;
  align-items: baseline;
  gap: 10px;
  font-family: var(--f-display);
  font-weight: 600;
  font-style: italic;
  font-size: 22px;
  color: var(--c-ink);
  letter-spacing: -0.01em;
  text-decoration: none;
}
.brand span {
  font-family: var(--f-head);
  font-style: normal;
  font-weight: 700;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: var(--c-sage-deep);
  margin-left: 4px;
}
.brand:hover { text-decoration: none; }
.nav-meta {
  display: flex;
  align-items: center;
  gap: 22px;
}
.nav-link {
  font-family: var(--f-head);
  font-weight: 600;
  font-size: 12.5px;
  letter-spacing: 0.04em;
  color: var(--c-ink-soft);
  text-decoration: none;
}
.nav-link:hover { color: var(--c-orange); text-decoration: none; }
.nav-cta { font-size: 11.5px; padding: 11px 18px; }

/* ============================================================
   01. HERO — asymmetric editorial composition
   Left column: kicker + display headline + lede + CTAs + Mia quote
   Right column: portrait module (cream card) + meta strip
   Background: subtle paper texture using radial-gradient noise
   ============================================================ */
.hero {
  position: relative;
  background: var(--c-bone);
  padding: 56px 0 40px;
  overflow: hidden;
  border-bottom: 1px solid var(--c-border-soft);
}
/* Paper-grain ornament */
.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(1200px 540px at 88% -10%, rgba(135,182,186,0.18), transparent 65%),
    radial-gradient(900px 420px at -5% 110%, rgba(255,144,0,0.06), transparent 60%);
  pointer-events: none;
}
.hero::after {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(rgba(43,48,51,0.045) 1px, transparent 1px);
  background-size: 4px 4px;
  mix-blend-mode: multiply;
  opacity: 0.4;
  pointer-events: none;
}
.hero .container { position: relative; z-index: 1; }

.hero-grid {
  display: grid;
  grid-template-columns: 1.25fr 1fr;
  gap: 64px;
  align-items: center;
  padding-top: 24px;
}
.hero-meta {
  display: inline-flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0 14px;
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--c-sage-deep);
  margin-bottom: 26px;
}
.hero-meta .dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--c-orange);
  display: inline-block;
}
.hero h1 {
  font-family: var(--f-display);
  font-weight: 400;
  font-size: clamp(44px, 6.6vw, 92px);
  line-height: 0.98;
  letter-spacing: -0.025em;
  color: var(--c-ink);
  margin: 0 0 28px;
}
.hero h1 em {
  font-style: italic;
  font-weight: 400;
  color: var(--c-sage-deep);
}
.hero h1 .underline {
  position: relative;
  white-space: nowrap;
}
.hero h1 .underline::after {
  content: "";
  position: absolute;
  left: 0; right: 0;
  bottom: -4px;
  height: 8px;
  background: var(--c-orange);
  opacity: 0.85;
  transform: skewX(-8deg);
  z-index: -1;
}
.hero .lede {
  font-family: var(--f-sub);
  font-size: 19px;
  line-height: 1.55;
  color: var(--c-text-strong);
  max-width: 540px;
  margin: 0 0 32px;
}
.hero-ctas {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 36px;
}
.hero-promise {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 14px 18px;
  border-top: 1px solid var(--c-border-soft);
  padding-top: 24px;
  max-width: 520px;
}
.hero-promise dt {
  font-family: var(--f-mono);
  font-size: 11px;
  letter-spacing: 0.06em;
  color: var(--c-muted);
  align-self: center;
}
.hero-promise dd {
  margin: 0;
  font-family: var(--f-sub);
  font-size: 15px;
  color: var(--c-text-strong);
}

/* Right column: portrait module */
.portrait {
  position: relative;
  align-self: stretch;
  padding-left: 0;
}
.portrait-frame {
  position: relative;
  background: var(--c-cream);
  border-radius: var(--radius-md);
  padding: 28px 28px 22px;
  border: 1px solid var(--c-cream-deep);
  box-shadow: 0 30px 60px -30px rgba(43,48,51,0.18);
  transform: rotate(0.4deg);
}
.portrait-frame::before {
  content: "30+ Years · Real-World Experience";
  position: absolute;
  top: 18px;
  left: 50%;
  transform: translateX(-50%);
  font-family: var(--f-mono);
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--c-sage-deep);
  opacity: 0.7;
  pointer-events: none;
}
.portrait-img {
  position: relative;
  border-radius: var(--radius-sm);
  overflow: hidden;
  margin-top: 28px;
  aspect-ratio: 4 / 5;
  background: linear-gradient(180deg, var(--c-sage-tint), var(--c-cream-deep));
}
.portrait-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
  filter: contrast(1.02) saturate(0.95);
}
.portrait-img::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 60%, rgba(26,29,30,0.18));
  pointer-events: none;
}
.portrait-meta {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: 20px;
  padding-top: 16px;
  border-top: 1px solid var(--c-cream-deep);
  font-family: var(--f-mono);
  font-size: 11px;
  letter-spacing: 0.05em;
  color: var(--c-ink-soft);
}
.portrait-meta strong {
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 500;
  font-size: 17px;
  letter-spacing: -0.01em;
  display: block;
  color: var(--c-ink);
  margin-bottom: 2px;
}
.portrait-meta .role {
  font-family: var(--f-head);
  font-style: normal;
  font-weight: 600;
  text-transform: uppercase;
  font-size: 10px;
  letter-spacing: 0.16em;
  color: var(--c-sage-deep);
}
.portrait-stat {
  text-align: right;
}
.portrait-stat .num {
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 500;
  font-size: 30px;
  line-height: 1;
  color: var(--c-orange);
  display: block;
}
.portrait-stat .lbl {
  font-family: var(--f-head);
  font-weight: 600;
  text-transform: uppercase;
  font-size: 9.5px;
  letter-spacing: 0.16em;
  color: var(--c-muted);
  margin-top: 4px;
  display: block;
}

/* Floating Mia pull-quote — overlap onto portrait */
.mia-pull {
  position: absolute;
  left: -18%;
  bottom: -8%;
  max-width: 320px;
  background: var(--c-ink);
  color: var(--c-bone);
  padding: 22px 24px 20px;
  border-radius: var(--radius-md);
  box-shadow: 0 30px 60px -20px rgba(26,29,30,0.45);
  transform: rotate(-1.5deg);
}
.mia-pull blockquote {
  margin: 0 0 10px;
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 400;
  font-size: 17px;
  line-height: 1.4;
  color: var(--c-bone);
}
.mia-pull cite {
  font-family: var(--f-head);
  font-style: normal;
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--c-orange);
}
.mia-pull cite span {
  display: block;
  font-weight: 500;
  text-transform: none;
  letter-spacing: 0;
  color: rgba(250,247,241,0.7);
  font-size: 11.5px;
  margin-top: 2px;
}

/* Hero promise row — three pillars under hero */
.support-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border-top: 1px solid var(--c-border-soft);
  margin-top: 80px;
  padding-top: 36px;
}
.support-item {
  padding: 0 24px;
  border-right: 1px solid var(--c-border-soft);
  position: relative;
}
.support-item:first-child { padding-left: 0; }
.support-item:last-child { border-right: 0; padding-right: 0; }
.support-item .num {
  font-family: var(--f-mono);
  font-size: 11px;
  letter-spacing: 0.05em;
  color: var(--c-orange);
  margin-bottom: 14px;
  display: block;
}
.support-item h3 {
  font-family: var(--f-display);
  font-weight: 500;
  font-size: 24px;
  line-height: 1.15;
  letter-spacing: -0.015em;
  color: var(--c-ink);
  margin: 0 0 10px;
}
.support-item p {
  font-size: 15px;
  line-height: 1.6;
  color: var(--c-text);
  margin: 0;
}

/* ============================================================
   02. LOGO STRIP
   ============================================================ */
.logo-strip {
  background: var(--c-bone);
  padding: 30px 0;
  border-top: 1px solid var(--c-border-soft);
  border-bottom: 1px solid var(--c-border-soft);
}
.logo-strip-inner {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 36px;
  align-items: center;
}
.logo-strip .label {
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 400;
  color: var(--c-ink-soft);
  font-size: 16px;
  line-height: 1.2;
  max-width: 200px;
}
.logo-row {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 28px;
  align-items: center;
}
.logo-tile {
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  filter: grayscale(1);
  opacity: 0.55;
  transition: opacity 220ms var(--ease), filter 220ms var(--ease);
}
.logo-tile:hover { opacity: 1; filter: grayscale(0); }
.logo-tile img { max-height: 28px; max-width: 100%; object-fit: contain; }
.logo-text {
  font-family: var(--f-head);
  font-weight: 600;
  letter-spacing: 0.04em;
  font-size: 13px;
  color: var(--c-muted);
  text-align: center;
}
.logo-text--lower { text-transform: lowercase; letter-spacing: 0.01em; font-weight: 700; }

/* ============================================================
   03. THE REAL PROBLEM — editorial column with side rail
   ============================================================ */
.problem {
  background: var(--c-bone);
  padding: 120px 0;
}
.problem-grid {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 80px;
  align-items: start;
}
.problem-rail {
  position: sticky;
  top: 110px;
}
.problem-rail .marker {
  font-family: var(--f-mono);
  font-size: 11px;
  letter-spacing: 0.06em;
  color: var(--c-muted);
  margin-bottom: 14px;
  display: block;
}
.problem-rail h2 {
  font-family: var(--f-display);
  font-weight: 400;
  font-size: clamp(34px, 3.4vw, 50px);
  line-height: 1.05;
  letter-spacing: -0.02em;
  color: var(--c-ink);
  margin: 0;
}
.problem-rail h2 em { font-style: italic; color: var(--c-sage-deep); }
.problem-body p {
  font-family: var(--f-body);
  font-size: 18px;
  line-height: 1.78;
  color: var(--c-text-strong);
}
.problem-body p:first-of-type::first-letter {
  font-family: var(--f-display);
  font-weight: 500;
  font-size: 64px;
  float: left;
  line-height: 0.9;
  margin: 6px 12px 0 0;
  color: var(--c-orange);
}
.problem-body strong { color: var(--c-ink); }
.problem-quote {
  margin: 36px 0 0;
  padding: 28px 0 0;
  border-top: 2px solid var(--c-ink);
}
.problem-quote blockquote {
  margin: 0;
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(22px, 2.4vw, 28px);
  line-height: 1.3;
  color: var(--c-ink);
  letter-spacing: -0.005em;
}
.problem-quote cite {
  display: block;
  margin-top: 14px;
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--c-sage-deep);
  font-style: normal;
}

/* ============================================================
   04. WHY SIMON — dark editorial spread
   ============================================================ */
.why-simon {
  background: var(--c-ink);
  color: var(--c-bone);
  padding: 120px 0;
  position: relative;
  overflow: hidden;
}
.why-simon::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(700px 320px at 90% 0%, rgba(135,182,186,0.16), transparent 70%),
    radial-gradient(800px 380px at -10% 100%, rgba(255,144,0,0.07), transparent 70%);
  pointer-events: none;
}
.why-simon::after {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 4px 4px;
  pointer-events: none;
}
.why-simon .container { position: relative; z-index: 1; }

.simon-head { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end; margin-bottom: 64px; }
.simon-head h2 {
  color: #fff;
  font-family: var(--f-display);
  font-weight: 400;
  font-size: clamp(34px, 4.2vw, 56px);
  line-height: 1.05;
  letter-spacing: -0.02em;
  margin: 0;
}
.simon-head h2 em { font-style: italic; color: var(--c-sage-bright); }
.simon-head .lede {
  color: rgba(250,247,241,0.78);
  font-family: var(--f-sub);
  font-size: 18px;
  line-height: 1.55;
  margin: 0;
}

.simon-grid {
  display: grid;
  grid-template-columns: 380px 1fr;
  gap: 64px;
  align-items: start;
}
.simon-portrait {
  position: relative;
  border-radius: var(--radius-md);
  overflow: hidden;
  aspect-ratio: 4/5;
  background: var(--c-sage-deep);
  box-shadow: 0 30px 80px -20px rgba(0,0,0,0.5);
}
.simon-portrait img {
  width: 100%; height: 100%; object-fit: cover; object-position: center 30%;
  filter: contrast(1.05) saturate(0.92);
}
.simon-portrait .badge {
  position: absolute;
  top: 18px;
  left: 18px;
  background: rgba(26,29,30,0.7);
  backdrop-filter: blur(6px);
  color: var(--c-bone);
  font-family: var(--f-mono);
  font-size: 10.5px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 7px 11px;
  border-radius: 4px;
  border: 1px solid rgba(255,255,255,0.12);
}
.simon-bio p {
  color: rgba(250,247,241,0.85);
  font-size: 17px;
  line-height: 1.7;
}
.simon-bio strong { color: #fff; }
.simon-bio .brand-list {
  font-family: var(--f-sub);
  font-style: italic;
  color: var(--c-sage-bright);
  font-size: 17px;
  margin: 28px 0 0;
  border-top: 1px solid rgba(255,255,255,0.12);
  padding-top: 22px;
}
.simon-bio .brand-list strong { color: #fff; font-style: normal; }

.testimonial-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-top: 80px;
}
.testimonial {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 30px 28px;
  border-radius: var(--radius-md);
  position: relative;
  transition: transform 280ms var(--ease), background 280ms var(--ease), border-color 280ms var(--ease);
}
.testimonial:hover {
  transform: translateY(-3px);
  background: rgba(255,255,255,0.07);
  border-color: rgba(135,182,186,0.4);
}
.testimonial::before {
  content: "“";
  position: absolute;
  top: 4px;
  right: 18px;
  font-family: var(--f-display);
  font-style: italic;
  font-size: 80px;
  color: var(--c-sage-bright);
  opacity: 0.4;
  line-height: 1;
}
.testimonial blockquote {
  margin: 0 0 18px;
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 400;
  font-size: 19px;
  line-height: 1.4;
  color: var(--c-bone);
}
.testimonial cite {
  font-family: var(--f-head);
  font-style: normal;
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--c-orange);
}
.testimonial cite span {
  display: block;
  font-weight: 500;
  text-transform: none;
  letter-spacing: 0;
  color: rgba(250,247,241,0.6);
  font-size: 12.5px;
  margin-top: 4px;
}

.mid-cta {
  display: flex;
  justify-content: center;
  gap: 14px;
  flex-wrap: wrap;
  margin-top: 64px;
}

/* ============================================================
   05. CURRICULUM — segmented control / side-tab pattern
   ============================================================ */
.curriculum { background: var(--c-bone); padding: 120px 0; }
.curriculum-head { text-align: left; max-width: 720px; margin-bottom: 56px; }
.curriculum-head h2 em { font-style: italic; color: var(--c-sage-deep); }

.curriculum-shell {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 48px;
  align-items: start;
  background: var(--c-bg);
  border: 1px solid var(--c-border-soft);
  border-radius: var(--radius-lg);
  padding: 8px;
  box-shadow: 0 1px 0 rgba(0,0,0,0.02), 0 30px 60px -40px rgba(43,48,51,0.18);
}
.tab-list {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 16px 8px;
  border-right: 1px solid var(--c-border-soft);
  margin-right: -48px; /* re-align border to grid gap */
  padding-right: 48px;
}
.tab-btn {
  appearance: none;
  background: transparent;
  border: 0;
  text-align: left;
  padding: 18px 18px;
  cursor: pointer;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  gap: 14px;
  transition: background 200ms var(--ease), color 200ms var(--ease);
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 14px;
  color: var(--c-ink-soft);
  line-height: 1.3;
  position: relative;
}
.tab-btn .num {
  font-family: var(--f-mono);
  font-size: 11px;
  font-weight: 500;
  color: var(--c-muted);
  letter-spacing: 0.06em;
  flex-shrink: 0;
}
.tab-btn:hover { background: var(--c-cream); color: var(--c-ink); }
.tab-btn[aria-selected="true"] {
  background: var(--c-ink);
  color: var(--c-bone);
}
.tab-btn[aria-selected="true"] .num { color: var(--c-orange); }
.tab-btn[aria-selected="true"]::after {
  content: "→";
  margin-left: auto;
  font-family: var(--f-mono);
  color: var(--c-orange);
}

.tab-panels { padding: 32px 32px 32px 0; }
.tab-panel { display: none; animation: fadeUp 360ms var(--ease); }
.tab-panel[data-active] { display: block; }
.tab-panel .panel-head {
  display: flex;
  align-items: baseline;
  gap: 16px;
  margin-bottom: 22px;
  padding-bottom: 18px;
  border-bottom: 1px solid var(--c-border-soft);
}
.tab-panel .panel-head .num {
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 400;
  font-size: 36px;
  line-height: 1;
  color: var(--c-orange);
}
.tab-panel .panel-head h3 {
  font-family: var(--f-display);
  font-weight: 400;
  font-size: 28px;
  line-height: 1.1;
  letter-spacing: -0.015em;
  color: var(--c-ink);
  margin: 0;
}
.tab-panel ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px 32px;
}
.tab-panel li {
  padding: 8px 0 8px 28px;
  position: relative;
  font-size: 15px;
  line-height: 1.5;
  border-bottom: 1px dashed var(--c-border-soft);
  margin: 0;
  color: var(--c-text-strong);
}
.tab-panel li::before {
  content: "+";
  position: absolute;
  left: 0;
  top: 8px;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: var(--c-sage-tint);
  color: var(--c-sage-deep);
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 12px;
  text-align: center;
  line-height: 18px;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ============================================================
   06. HOW IT WORKS — sage panel + 6-card grid with vertical num
   ============================================================ */
.how-works {
  background: var(--c-sage-mist);
  padding: 120px 0;
  position: relative;
}
.how-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px;
  margin-top: 40px;
  margin-bottom: 64px;
}
.how-card {
  background: #fff;
  border: 1px solid var(--c-border-soft);
  border-radius: var(--radius-md);
  padding: 32px 32px;
  transition: transform 280ms var(--ease), box-shadow 280ms var(--ease);
}
.how-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 24px 50px -30px rgba(43,48,51,0.18);
}
.how-card h4 {
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--c-sage-deep);
  margin: 0 0 16px;
}
.how-card .head-display {
  font-family: var(--f-display);
  font-weight: 400;
  font-size: 26px;
  line-height: 1.15;
  letter-spacing: -0.015em;
  color: var(--c-ink);
  margin: 0 0 18px;
}
.how-card .head-display em { font-style: italic; color: var(--c-sage-deep); }

.check-list { list-style: none; padding: 0; margin: 0; }
.check-list li {
  padding: 10px 0 10px 32px;
  position: relative;
  font-size: 15.5px;
  border-bottom: 1px solid var(--c-border-soft);
  margin: 0;
  color: var(--c-text-strong);
}
.check-list li:last-child { border-bottom: 0; }
.check-list li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 17px;
  width: 16px;
  height: 9px;
  border-left: 2px solid var(--c-orange);
  border-bottom: 2px solid var(--c-orange);
  transform: rotate(-45deg);
}

.x-list { list-style: none; padding: 0; margin: 0; }
.x-list li {
  padding: 10px 0 10px 32px;
  position: relative;
  font-size: 15.5px;
  border-bottom: 1px solid var(--c-border-soft);
  margin: 0;
  color: var(--c-text-strong);
}
.x-list li:last-child { border-bottom: 0; }
.x-list li::before {
  content: "";
  position: absolute;
  left: 2px;
  top: 19px;
  width: 14px;
  height: 2px;
  background: var(--c-red);
  transform: rotate(-45deg);
}
.x-list li::after {
  content: "";
  position: absolute;
  left: 2px;
  top: 19px;
  width: 14px;
  height: 2px;
  background: var(--c-red);
  transform: rotate(45deg);
}

.included-h4 {
  font-family: var(--f-display);
  font-weight: 400;
  font-style: italic;
  font-size: 30px;
  text-align: center;
  color: var(--c-ink);
  margin: 56px 0 28px;
}
.included-table {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  background: #fff;
  border: 1px solid var(--c-border-soft);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.inclusion-card {
  padding: 28px 28px;
  border-right: 1px solid var(--c-border-soft);
  border-bottom: 1px solid var(--c-border-soft);
  position: relative;
  transition: background 220ms var(--ease);
}
.inclusion-card:hover { background: var(--c-cream); }
.inclusion-card:nth-child(3n) { border-right: 0; }
.inclusion-card:nth-last-child(-n+3) { border-bottom: 0; }
.inclusion-card .num {
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 500;
  font-size: 28px;
  color: var(--c-orange);
  line-height: 1;
  margin-bottom: 14px;
  display: block;
}
.inclusion-card h3 {
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 16px;
  margin: 0 0 8px;
  color: var(--c-ink);
}
.inclusion-card p { font-size: 14.5px; line-height: 1.55; margin: 0; }

.alone-quote {
  text-align: center;
  margin-top: 56px;
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(26px, 3vw, 38px);
  line-height: 1.2;
  letter-spacing: -0.015em;
  color: var(--c-ink);
}
.alone-quote::before, .alone-quote::after {
  content: "—";
  color: var(--c-orange);
  margin: 0 14px;
  font-style: normal;
}

/* ============================================================
   07. FIT — two-column compare + audience strip
   ============================================================ */
.fit { background: var(--c-bone); padding: 120px 0; }
.fit-head { text-align: center; margin-bottom: 56px; }
.fit-head h2 em { font-style: italic; color: var(--c-sage-deep); }

.compare {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px;
  margin-bottom: 64px;
}
.compare-card {
  background: #fff;
  border: 1px solid var(--c-border-soft);
  border-radius: var(--radius-md);
  padding: 36px 32px;
  position: relative;
  overflow: hidden;
}
.compare-card .label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--f-mono);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 14px;
}
.compare-card.yes .label { color: var(--c-sage-deep); }
.compare-card.yes .label::before { content: "✓"; font-family: var(--f-head); font-weight: 700; font-size: 14px; }
.compare-card.no .label { color: var(--c-red); }
.compare-card.no .label::before { content: "✗"; font-family: var(--f-head); font-weight: 700; font-size: 14px; }
.compare-card h3 {
  font-family: var(--f-display);
  font-weight: 400;
  font-size: 28px;
  line-height: 1.1;
  letter-spacing: -0.015em;
  color: var(--c-ink);
  margin: 0 0 24px;
}
.compare-card h3 em { font-style: italic; }

.audience-strip {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  background: var(--c-ink);
  color: var(--c-bone);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.audience-strip > div { padding: 36px 36px; border-right: 1px solid rgba(255,255,255,0.08); }
.audience-strip > div:last-child { border-right: 0; }
.audience-strip h4 {
  font-family: var(--f-head);
  font-weight: 700;
  color: var(--c-sage-bright);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  margin: 0 0 18px;
}
.audience-strip ul { list-style: none; padding: 0; margin: 0; }
.audience-strip li {
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 400;
  font-size: 19px;
  line-height: 1.45;
  color: var(--c-bone);
  padding: 6px 0;
  border-bottom: 1px dashed rgba(255,255,255,0.1);
}
.audience-strip li:last-child { border-bottom: 0; }

/* ============================================================
   08. PRICING + ROI — bespoke ticket / receipt module
   ============================================================ */
.pricing-section {
  background:
    linear-gradient(180deg, var(--c-ink) 0%, #0c0e0f 100%);
  color: var(--c-bone);
  padding: 120px 0;
  position: relative;
  overflow: hidden;
}
.pricing-section::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(800px 400px at 20% 0%, rgba(255,144,0,0.08), transparent 70%),
    radial-gradient(900px 500px at 100% 100%, rgba(135,182,186,0.10), transparent 70%);
  pointer-events: none;
}
.pricing-section .container { position: relative; z-index: 1; }
.pricing-head { text-align: center; max-width: 760px; margin: 0 auto 56px; }
.pricing-head h2 {
  color: #fff;
  font-family: var(--f-display);
  font-weight: 400;
  font-size: clamp(34px, 4vw, 56px);
  line-height: 1.05;
  letter-spacing: -0.02em;
}
.pricing-head h2 em { font-style: italic; color: var(--c-sage-bright); }
.pricing-head .lede {
  color: rgba(250,247,241,0.78);
  font-family: var(--f-sub);
  font-size: 18px;
  margin: 18px auto 0;
  max-width: 580px;
  line-height: 1.55;
}

.roi-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border-top: 1px solid rgba(255,255,255,0.12);
  border-bottom: 1px solid rgba(255,255,255,0.12);
  margin: 0 0 56px;
  background: rgba(255,255,255,0.025);
  border-radius: 0;
}
.roi-item {
  padding: 32px 28px;
  border-right: 1px solid rgba(255,255,255,0.12);
  font-size: 15.5px;
  color: rgba(250,247,241,0.85);
  line-height: 1.55;
  position: relative;
}
.roi-item:last-child { border-right: 0; }
.roi-item .roi-num {
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 500;
  font-size: 56px;
  line-height: 1;
  color: var(--c-orange);
  margin-bottom: 14px;
  display: block;
  letter-spacing: -0.02em;
}
.roi-item strong { color: #fff; font-weight: 700; }

/* The ticket / pricing card */
.pricing-card {
  max-width: 580px;
  margin: 0 auto;
  background: var(--c-bone);
  color: var(--c-text);
  border-radius: var(--radius-md);
  padding: 0;
  text-align: left;
  box-shadow: 0 40px 80px -20px rgba(0,0,0,0.5);
  position: relative;
  overflow: hidden;
}
.pricing-card::before, .pricing-card::after {
  content: "";
  position: absolute;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--c-ink);
  top: 50%;
  transform: translateY(-50%);
}
.pricing-card::before { left: -14px; }
.pricing-card::after { right: -14px; }
.pricing-card .card-head {
  background: var(--c-cream);
  padding: 26px 36px;
  border-bottom: 2px dashed var(--c-cream-deep);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.pricing-card .card-head .label {
  font-family: var(--f-mono);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--c-ink-soft);
}
.pricing-card .card-head .badge {
  background: var(--c-orange);
  color: #fff;
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 10.5px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  padding: 6px 12px;
  border-radius: 20px;
}
.pricing-card .card-body { padding: 36px 36px 32px; }
.price-amount {
  font-family: var(--f-display);
  font-weight: 400;
  font-style: italic;
  font-size: 92px;
  color: var(--c-ink);
  line-height: 0.95;
  margin: 0 0 4px;
  letter-spacing: -0.04em;
}
.price-amount span {
  font-size: 17px;
  font-style: normal;
  font-family: var(--f-head);
  font-weight: 600;
  color: var(--c-muted);
  margin-left: 8px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.price-terms {
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--c-sage-deep);
  margin: 8px 0 24px;
  display: flex;
  flex-wrap: wrap;
  gap: 6px 12px;
}
.price-terms span::before { content: "·"; margin-right: 8px; color: var(--c-muted); }
.price-terms span:first-child::before { content: ""; margin-right: 0; }
.price-meta {
  font-family: var(--f-sub);
  color: var(--c-text);
  margin-bottom: 24px;
  font-size: 16px;
  line-height: 1.55;
}
.pricing-card .btn { width: 100%; justify-content: center; }
.pricing-fine {
  font-size: 12px;
  color: var(--c-muted);
  margin-top: 18px;
  text-align: center;
  font-family: var(--f-mono);
  letter-spacing: 0.04em;
  margin-bottom: 0;
}
.pricing-tail {
  text-align: center;
  margin-top: 48px;
  font-family: var(--f-display);
  font-style: italic;
  color: rgba(250,247,241,0.85);
  font-size: 19px;
  line-height: 1.5;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

/* ============================================================
   09. FAQ — wide editorial list
   ============================================================ */
.faq { background: var(--c-bone); padding: 120px 0; }
.faq-grid {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 80px;
  align-items: start;
}
.faq-aside { position: sticky; top: 110px; }
.faq-aside h2 em { font-style: italic; color: var(--c-sage-deep); }
.faq-aside p {
  font-family: var(--f-sub);
  font-size: 17px;
  line-height: 1.55;
  color: var(--c-text);
  margin-top: 18px;
}
.faq-list {
  border-top: 1.5px solid var(--c-ink);
}
.faq-list details {
  border-bottom: 1px solid var(--c-border-soft);
  transition: background 200ms var(--ease);
}
.faq-list details[open] { background: var(--c-cream); }
.faq-list summary {
  list-style: none;
  cursor: pointer;
  padding: 26px 56px 26px 0;
  position: relative;
  font-family: var(--f-display);
  font-weight: 400;
  font-size: 22px;
  line-height: 1.3;
  letter-spacing: -0.005em;
  color: var(--c-ink);
  display: block;
}
.faq-list summary::-webkit-details-marker { display: none; }
.faq-list summary::after {
  content: "";
  position: absolute;
  right: 6px;
  top: 50%;
  width: 18px;
  height: 18px;
  margin-top: -9px;
  background-image:
    linear-gradient(var(--c-ink), var(--c-ink)),
    linear-gradient(var(--c-ink), var(--c-ink));
  background-size: 18px 1.5px, 1.5px 18px;
  background-position: center, center;
  background-repeat: no-repeat;
  transition: transform 240ms var(--ease);
}
.faq-list details[open] summary::after {
  transform: rotate(45deg);
  background-size: 18px 1.5px, 0 0;
}
.faq-list details[open] summary { color: var(--c-orange); }
.faq-list details[open] summary { padding-left: 18px; padding-right: 70px; }
.faq-list .faq-body {
  padding: 0 70px 28px 18px;
  font-size: 16px;
  line-height: 1.7;
  font-family: var(--f-body);
  color: var(--c-text-strong);
}
.faq-list details:not([open]):hover summary { color: var(--c-sage-deep); }

/* ============================================================
   10. FINAL CTA — bespoke multi-step apply form on cream
   ============================================================ */
.final-cta {
  background:
    linear-gradient(135deg, var(--c-cream) 0%, var(--c-cream-deep) 100%);
  padding: 120px 0 140px;
  position: relative;
  overflow: hidden;
  border-top: 1px solid var(--c-cream-deep);
}
.final-cta::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(rgba(43,48,51,0.04) 1px, transparent 1px);
  background-size: 4px 4px;
  pointer-events: none;
}
.final-cta .container { position: relative; z-index: 1; }
.final-grid {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: 64px;
  align-items: start;
}
.final-cta h2 {
  color: var(--c-ink);
  font-family: var(--f-display);
  font-weight: 400;
  font-size: clamp(36px, 4.6vw, 64px);
  line-height: 1;
  letter-spacing: -0.025em;
  margin: 0 0 24px;
}
.final-cta h2 em { font-style: italic; color: var(--c-sage-deep); }
.final-cta .lede {
  font-family: var(--f-sub);
  font-size: 18px;
  line-height: 1.6;
  color: var(--c-ink-soft);
  margin: 0 0 28px;
  max-width: 460px;
}
.fit-call-link {
  margin-top: 28px;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--c-ink-soft);
  text-decoration: none;
  border-bottom: 1.5px solid var(--c-ink-soft);
  padding-bottom: 4px;
}
.fit-call-link:hover { color: var(--c-orange); border-color: var(--c-orange); text-decoration: none; }

/* The form — multi-step bespoke */
.apply-form {
  background: #fff;
  border: 1px solid var(--c-cream-deep);
  border-radius: var(--radius-md);
  padding: 36px 36px 32px;
  box-shadow: 0 30px 60px -30px rgba(43,48,51,0.22);
  position: relative;
}
.apply-form .form-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 28px;
  padding-bottom: 22px;
  border-bottom: 1px solid var(--c-border-soft);
}
.apply-form .form-header h3 {
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 400;
  font-size: 26px;
  color: var(--c-ink);
  margin: 0;
  letter-spacing: -0.015em;
}
.step-counter {
  font-family: var(--f-mono);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--c-muted);
}
.step-counter strong { color: var(--c-orange); font-weight: 700; }

.progress {
  display: flex;
  gap: 4px;
  margin-bottom: 26px;
}
.progress-segment {
  flex: 1;
  height: 3px;
  background: var(--c-border-soft);
  border-radius: 2px;
  transition: background 320ms var(--ease);
}
.progress-segment.active { background: var(--c-orange); }
.progress-segment.complete { background: var(--c-sage-deep); }

.form-step { display: none; }
.form-step.active { display: block; animation: fadeUp 360ms var(--ease); }
.field { margin-bottom: 18px; }
.field label {
  display: block;
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--c-ink);
  margin-bottom: 8px;
}
.field .hint {
  display: block;
  font-family: var(--f-sub);
  font-size: 13px;
  font-style: italic;
  color: var(--c-muted);
  margin-bottom: 8px;
  font-weight: 400;
  letter-spacing: 0;
  text-transform: none;
}
.field input,
.field select,
.field textarea {
  width: 100%;
  font-family: var(--f-body);
  font-size: 15.5px;
  padding: 13px 14px;
  border: 1px solid #d8d4cb;
  border-radius: var(--radius-sm);
  background: var(--c-bone);
  color: var(--c-ink);
  transition: border-color 200ms var(--ease), box-shadow 200ms var(--ease), background 200ms var(--ease);
}
.field input:focus,
.field select:focus,
.field textarea:focus {
  outline: none;
  border-color: var(--c-orange);
  box-shadow: 0 0 0 3px rgba(255,144,0,0.18);
  background: #fff;
}
.field textarea { resize: vertical; min-height: 100px; }

.form-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin-top: 22px;
}
.form-actions .btn { flex: 0 0 auto; }
.form-actions .back {
  appearance: none;
  background: transparent;
  border: 0;
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--c-muted);
  cursor: pointer;
  padding: 10px 0;
}
.form-actions .back:hover { color: var(--c-ink); }
.form-actions .back[hidden] { display: none; }
.form-fine {
  font-size: 12px;
  color: var(--c-muted);
  text-align: center;
  margin-top: 16px;
  font-family: var(--f-mono);
  letter-spacing: 0.04em;
}

/* Choice grid — radio cards for business type */
.choice-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.choice {
  position: relative;
  border: 1px solid var(--c-border-soft);
  border-radius: var(--radius-sm);
  padding: 14px 16px;
  cursor: pointer;
  background: var(--c-bone);
  transition: border-color 180ms var(--ease), background 180ms var(--ease);
  font-family: var(--f-head);
  font-weight: 600;
  font-size: 13.5px;
  color: var(--c-ink-soft);
  display: flex;
  align-items: center;
  gap: 14px;
  user-select: none;
}
.choice input { position: absolute; opacity: 0; pointer-events: none; }
.choice span:last-child {
  line-height: 1.35;
}
.choice .marker {
  width: 14px;
  height: 14px;
  border: 1.5px solid var(--c-border);
  border-radius: 50%;
  flex-shrink: 0;
  display: inline-block;
  position: relative;
  transition: border-color 180ms var(--ease);
}
.choice:hover { border-color: var(--c-sage); background: #fff; }
.choice input:checked ~ .marker {
  border-color: var(--c-orange);
}
.choice input:checked ~ .marker::after {
  content: "";
  position: absolute;
  inset: 3px;
  border-radius: 50%;
  background: var(--c-orange);
}
.choice:has(input:checked) { border-color: var(--c-orange); background: #fff; box-shadow: 0 0 0 3px rgba(255,144,0,0.12); color: var(--c-ink); }

/* ============================================================
   Sticky bottom CTA bar
   ============================================================ */
.sticky-bar {
  position: fixed;
  left: 16px;
  right: 16px;
  bottom: 16px;
  background: var(--c-ink);
  color: var(--c-bone);
  border-radius: var(--radius-md);
  box-shadow: 0 30px 60px -10px rgba(0,0,0,0.4);
  padding: 14px 18px;
  z-index: 60;
  display: none;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  transform: translateY(20px);
  opacity: 0;
  transition: opacity 300ms var(--ease), transform 300ms var(--ease);
}
.sticky-bar.visible {
  display: flex;
  transform: translateY(0);
  opacity: 1;
}
.sticky-bar .label {
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 13px;
  color: var(--c-bone);
  letter-spacing: 0.01em;
  flex: 1;
  min-width: 0;
}
.sticky-bar .label small {
  display: block;
  font-family: var(--f-mono);
  font-weight: 500;
  font-size: 11px;
  color: rgba(250,247,241,0.6);
  letter-spacing: 0.04em;
  text-transform: none;
  margin-top: 2px;
}
.sticky-bar .price-strong {
  color: var(--c-orange);
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 500;
  font-size: 18px;
}
.sticky-bar .btn { padding: 12px 20px; font-size: 11.5px; }

/* ============================================================
   Footer
   ============================================================ */
.site-footer {
  background: var(--c-footer);
  color: rgba(250,247,241,0.65);
  padding: 70px 0 32px;
  font-size: 14px;
  position: relative;
}
.site-footer .footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 56px;
  margin-bottom: 48px;
}
.site-footer h5 {
  color: #fff;
  font-family: var(--f-head);
  font-weight: 700;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  margin-bottom: 20px;
}
.site-footer .footer-mark {
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 400;
  font-size: 28px;
  color: #fff;
  margin: 0 0 14px;
  letter-spacing: -0.01em;
}
.site-footer a { color: rgba(250,247,241,0.65); text-decoration: none; }
.site-footer a:hover { color: var(--c-orange); }
.site-footer ul { list-style: none; padding: 0; margin: 0; }
.site-footer li { margin-bottom: 10px; font-size: 14.5px; }
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.06);
  padding-top: 26px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 12.5px;
  color: rgba(250,247,241,0.4);
  flex-wrap: wrap;
  gap: 12px;
  font-family: var(--f-mono);
  letter-spacing: 0.04em;
}

/* ============================================================
   Reveal-on-scroll (subtle, performance-friendly)
   ============================================================ */
[data-reveal] {
  opacity: 0;
  transform: translateY(14px);
  transition: opacity 700ms var(--ease), transform 700ms var(--ease);
  will-change: opacity, transform;
}
[data-reveal].in {
  opacity: 1;
  transform: translateY(0);
}

/* Respect reduced motion */
@media (prefers-reduced-motion: reduce) {
  * { transition: none !important; animation: none !important; }
  [data-reveal] { opacity: 1; transform: none; }
}

/* ============================================================
   Responsive
   ============================================================ */
@media (max-width: 1100px) {
  .hero-grid { grid-template-columns: 1.15fr 1fr; gap: 44px; }
  .simon-grid { grid-template-columns: 320px 1fr; gap: 44px; }
  .curriculum-shell { grid-template-columns: 280px 1fr; }
  .tab-list { margin-right: -32px; padding-right: 32px; }
  .tab-panels { padding-right: 24px; }
  .problem-grid { gap: 56px; }
  .faq-grid { gap: 56px; }
  .final-grid { gap: 44px; }
}

@media (max-width: 880px) {
  :root { --pad-y: 72px; }
  section { padding: 80px 0; }
  .problem, .why-simon, .curriculum, .how-works, .fit, .pricing-section, .faq, .final-cta { padding: 80px 0; }

  .hero { padding: 36px 0 32px; }
  .hero-grid { grid-template-columns: 1fr; gap: 32px; }
  .hero h1 { font-size: clamp(38px, 8vw, 60px); }
  .hero .lede { font-size: 17px; }
  .portrait { padding-left: 0; }
  .portrait-frame { transform: rotate(0); max-width: 460px; margin: 0 auto; }
  .mia-pull { left: auto; right: -10px; bottom: -16px; max-width: 260px; }
  .support-row { display: none; }

  .logo-strip-inner { grid-template-columns: 1fr; gap: 18px; }
  .logo-strip .label { max-width: none; text-align: center; }
  .logo-row { grid-template-columns: repeat(3, 1fr); gap: 22px; }

  .problem { padding: 80px 0; }
  .problem-grid { grid-template-columns: 1fr; gap: 28px; }
  .problem-rail { position: static; }

  .simon-head { grid-template-columns: 1fr; gap: 20px; }
  .simon-grid { grid-template-columns: 1fr; gap: 32px; }
  .simon-portrait { max-width: 420px; }
  .testimonial-grid { grid-template-columns: 1fr; gap: 16px; margin-top: 48px; }

  .curriculum-shell { grid-template-columns: 1fr; padding: 12px; }
  .tab-list { flex-direction: row; overflow-x: auto; gap: 4px; padding: 6px; margin: 0; border-right: 0; border-bottom: 1px solid var(--c-border-soft); }
  .tab-btn { flex: 0 0 auto; padding: 12px 16px; font-size: 13px; }
  .tab-btn[aria-selected="true"]::after { display: none; }
  .tab-panels { padding: 22px 18px; }
  .tab-panel ul { grid-template-columns: 1fr; }

  .how-grid { grid-template-columns: 1fr; gap: 18px; }
  .included-table { grid-template-columns: 1fr; }
  .inclusion-card { border-right: 0; }
  .inclusion-card:nth-last-child(-n+1) { border-bottom: 0; }
  .inclusion-card { border-bottom: 1px solid var(--c-border-soft); }
  .inclusion-card:last-child { border-bottom: 0; }

  .compare { grid-template-columns: 1fr; gap: 18px; }
  .audience-strip { grid-template-columns: 1fr; }
  .audience-strip > div { border-right: 0; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .audience-strip > div:last-child { border-bottom: 0; }

  .roi-grid { grid-template-columns: 1fr; }
  .roi-item { border-right: 0; border-bottom: 1px solid rgba(255,255,255,0.12); }
  .roi-item:last-child { border-bottom: 0; }

  .faq-grid { grid-template-columns: 1fr; gap: 32px; }
  .faq-aside { position: static; }

  .final-grid { grid-template-columns: 1fr; gap: 32px; }
  .footer-grid { grid-template-columns: 1fr; gap: 32px; }

  body.has-sticky { padding-bottom: 90px; }
}

@media (max-width: 540px) {
  .container { padding: 0 22px; }
  .hero-ctas { flex-direction: column; align-items: stretch; }
  .hero-ctas .btn { width: 100%; justify-content: center; }
  .pricing-card .card-head { padding: 22px 24px; flex-direction: column; align-items: flex-start; gap: 10px; }
  .pricing-card .card-body { padding: 28px 24px; }
  .price-amount { font-size: 76px; }
  .apply-form { padding: 28px 22px; }
  .choice-grid { grid-template-columns: 1fr; }
  .faq-list summary { font-size: 19px; padding-right: 50px; }
  .faq-list .faq-body { padding-right: 18px; }
  .logo-row { grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .form-actions { flex-direction: column-reverse; align-items: stretch; }
  .form-actions .btn { width: 100%; justify-content: center; }
  .form-actions .back { text-align: left; }
}

/* ============================================================
   V4 ADDITIONS
   ============================================================ */

/* --- Premium icons on the three hero support points --- */
.support-item .s-icon {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--c-cream);
  border: 1px solid var(--c-cream-deep);
  color: var(--c-sage-deep);
  margin-bottom: 18px;
  box-shadow: 0 8px 18px -10px rgba(43,48,51,0.22);
}
.support-item .s-icon svg { width: 22px; height: 22px; stroke: currentColor; stroke-width: 1.6; fill: none; stroke-linecap: round; stroke-linejoin: round; }

/* --- WHO IT'S FOR --- */
.who-for { background: var(--c-bone); padding: 96px 0; border-bottom: 1px solid var(--c-border-soft); }
.who-for-head { max-width: 820px; margin-bottom: 48px; }
.who-for-head h2 em { font-style: italic; color: var(--c-sage-deep); }
.who-for-head .lede {
  font-family: var(--f-sub);
  font-size: 19px;
  line-height: 1.55;
  color: var(--c-text-strong);
  margin: 18px 0 0;
}
.who-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-bottom: 36px;
}
.who-card {
  background: #fff;
  border: 1px solid var(--c-border-soft);
  border-radius: var(--radius-md);
  padding: 30px 28px;
  transition: transform 280ms var(--ease), box-shadow 280ms var(--ease);
}
.who-card:hover { transform: translateY(-3px); box-shadow: 0 24px 50px -30px rgba(43,48,51,0.18); }
.who-card .w-icon {
  width: 42px; height: 42px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  background: var(--c-sage-tint); color: var(--c-sage-deep); margin-bottom: 18px;
}
.who-card .w-icon svg { width: 22px; height: 22px; stroke: currentColor; stroke-width: 1.6; fill: none; stroke-linecap: round; stroke-linejoin: round; }
.who-card h3 { font-family: var(--f-head); font-weight: 700; font-size: 18px; color: var(--c-ink); margin: 0 0 8px; }
.who-card p { font-size: 15px; line-height: 1.6; margin: 0; }
.who-callout {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18px;
  background: var(--c-ink);
  color: var(--c-bone);
  border-radius: var(--radius-md);
  padding: 26px 32px;
  text-align: center;
  flex-wrap: wrap;
}
.who-callout strong {
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(22px, 2.4vw, 30px);
  color: #fff;
  line-height: 1.2;
}
.who-callout span { font-family: var(--f-display); font-style: italic; color: var(--c-orange); }

/* --- TRANSFORM BAND (chaos -> system) --- */
.transform { background: var(--c-sage-mist); padding: 110px 0; }
.transform-head { text-align: center; max-width: 820px; margin: 0 auto 56px; }
.transform-head h2 em { font-style: italic; color: var(--c-sage-deep); }
.transform-grid {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 28px;
  align-items: stretch;
}
.transform-col {
  background: #fff;
  border: 1px solid var(--c-border-soft);
  border-radius: var(--radius-md);
  padding: 34px 32px;
}
.transform-col.before { background: #fff; }
.transform-col.after { background: var(--c-ink); border-color: var(--c-ink); }
.transform-col .t-label {
  font-family: var(--f-mono);
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: 6px;
  display: block;
}
.transform-col.before .t-label { color: var(--c-red); }
.transform-col.after .t-label { color: var(--c-sage-bright); }
.transform-col h3 {
  font-family: var(--f-display);
  font-weight: 400;
  font-size: 26px;
  line-height: 1.1;
  letter-spacing: -0.015em;
  margin: 0 0 22px;
}
.transform-col.before h3 { color: var(--c-ink); }
.transform-col.after h3 { color: #fff; }
.transform-col ul { list-style: none; padding: 0; margin: 0; }
.transform-col li {
  padding: 11px 0 11px 30px;
  position: relative;
  font-size: 15.5px;
  line-height: 1.5;
  border-bottom: 1px solid var(--c-border-soft);
}
.transform-col li:last-child { border-bottom: 0; }
.transform-col.before li { color: var(--c-text-strong); }
.transform-col.after li { color: rgba(250,247,241,0.88); border-bottom-color: rgba(255,255,255,0.1); }
.transform-col.before li::before {
  content: ""; position: absolute; left: 4px; top: 19px;
  width: 13px; height: 2px; background: var(--c-red); transform: rotate(-45deg);
}
.transform-col.before li::after {
  content: ""; position: absolute; left: 4px; top: 19px;
  width: 13px; height: 2px; background: var(--c-red); transform: rotate(45deg);
}
.transform-col.after li::before {
  content: ""; position: absolute; left: 0; top: 18px;
  width: 15px; height: 8px; border-left: 2px solid var(--c-orange); border-bottom: 2px solid var(--c-orange); transform: rotate(-45deg);
}
.transform-arrow {
  align-self: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  color: var(--c-sage-deep);
}
.transform-arrow svg { width: 34px; height: 34px; stroke: currentColor; stroke-width: 1.4; fill: none; stroke-linecap: round; stroke-linejoin: round; }
.transform-arrow span {
  font-family: var(--f-mono); font-size: 10px; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--c-muted); writing-mode: horizontal-tb;
}
.transform-strap {
  text-align: center;
  margin-top: 48px;
  font-family: var(--f-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(24px, 2.8vw, 34px);
  line-height: 1.25;
  letter-spacing: -0.015em;
  color: var(--c-ink);
}
.transform-strap b { font-style: normal; font-weight: 400; color: var(--c-orange); }

/* --- VIDEO TESTIMONIALS --- */
.video-testimonials { background: var(--c-bone); padding: 110px 0; }
.vt-head { text-align: center; max-width: 760px; margin: 0 auto 52px; }
.vt-head h2 em { font-style: italic; color: var(--c-sage-deep); }
.vt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }
.vt-card {
  background: #fff;
  border: 1px solid var(--c-border-soft);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: 0 1px 0 rgba(0,0,0,0.02), 0 30px 60px -44px rgba(43,48,51,0.2);
}
.vt-embed {
  position: relative;
  aspect-ratio: 16 / 9;
  background: linear-gradient(135deg, var(--c-ink) 0%, #2b3033 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.vt-embed iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
.vt-embed .vt-play {
  position: relative;
  z-index: 2;
  width: 66px; height: 66px;
  border-radius: 50%;
  background: rgba(255,144,0,0.95);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 10px 30px -6px rgba(255,144,0,0.5);
}
.vt-embed .vt-play::after {
  content: ""; display: block;
  border-left: 18px solid #fff;
  border-top: 11px solid transparent;
  border-bottom: 11px solid transparent;
  margin-left: 5px;
}
.vt-embed .vt-placeholder-note {
  position: absolute; bottom: 14px; left: 0; right: 0;
  text-align: center;
  font-family: var(--f-mono); font-size: 10.5px; letter-spacing: 0.1em;
  text-transform: uppercase; color: rgba(250,247,241,0.55);
}
.vt-meta { padding: 22px 26px 24px; }
.vt-meta blockquote {
  margin: 0 0 14px;
  font-family: var(--f-display); font-style: italic; font-weight: 400;
  font-size: 18px; line-height: 1.4; color: var(--c-ink);
}
.vt-meta cite {
  font-family: var(--f-head); font-style: normal; font-weight: 700;
  font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--c-sage-deep);
}
.vt-meta cite span { display: block; font-weight: 500; text-transform: none; letter-spacing: 0; color: var(--c-muted); font-size: 13px; margin-top: 3px; }

@media (max-width: 880px) {
  .who-for { padding: 72px 0; }
  .who-grid { grid-template-columns: 1fr; gap: 16px; }
  .transform { padding: 72px 0; }
  .transform-grid { grid-template-columns: 1fr; gap: 18px; }
  .transform-arrow { transform: rotate(90deg); margin: 0 auto; }
  .video-testimonials { padding: 72px 0; }
  .vt-grid { grid-template-columns: 1fr; gap: 20px; }
}

/* --- Overflow / small-screen hardening (v4) --- */
.hero-grid > *, .hero-text { min-width: 0; }
.hero-meta { max-width: 100%; }
/* Footer never collapsed on mobile in v3: the media-query rule was less
   specific than the base `.site-footer .footer-grid`. Override correctly. */
